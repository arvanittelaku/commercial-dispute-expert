# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://commercialdisputeexpert.com

# Contact form — Resend (https://resend.com) or leave empty to log submissions server-side
RESEND_API_KEY=
CONTACT_EMAIL=contact@commercialdisputeexpert.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Lead webhook (n8n etc.) — POST on form submit with Full Name, Email, Phone Number, Brand name
# Set in Netlify → Environment variables; use .env for `netlify dev` (do not commit real URLs)
Lead_notification_url=
# LEAD_NOTIFICATION_URL=   # accepted fallback

# Google Sheets — contact form rows (see docs/google-sheets.md for column headers)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB_NAME=Sheet8

# --- Tracking (loaded only after cookie consent) ---
# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Plausible domain (e.g. commercialdisputeexpert.com)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Hotjar site ID (numeric)
NEXT_PUBLIC_HOTJAR_ID=
# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=
# LinkedIn Insight Tag partner ID
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
